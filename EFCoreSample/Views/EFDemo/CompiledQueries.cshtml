@{ViewData["Title"] = "編譯查詢";}
<div class="container mt-4">
    <h2>8. 編譯查詢 (Compiled Queries)</h2>
    <a asp-action="Index" class="btn btn-outline-secondary mb-3">← 返回</a>
    <div class="card">
        <div class="card-header">EF.CompileAsyncQuery 結果</div>
        <div class="card-body">
            <ol>@foreach(var r in (List<string>)ViewBag.Results){<li>@r</li>}</ol>
            @if(ViewBag.Blog != null){<p>部落格名稱: @ViewBag.Blog.Name</p>}
        </div>
    </div>
    <div class="card mt-3">
        <div class="card-header">說明</div>
        <div class="card-body">
            <p>編譯查詢透過預先編譯 LINQ 到 SQL 的轉換過程，可以提升重複執行查詢的效能。適合在熱路徑 (hot path) 中使用。</p>
        </div>
    </div>
</div>
